# ─────────────────────────────────────────────────────────────────────────────
# Yaffa Law API — Environment Variables
#
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# This file (.env.example) is safe to commit — it contains no secrets.
# ─────────────────────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════════════════════════════════════════
# CORE SERVER
# ═══════════════════════════════════════════════════════════════════════════════
PORT=4000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development


# ═══════════════════════════════════════════════════════════════════════════════
# SUPABASE (REQUIRED)
# ═══════════════════════════════════════════════════════════════════════════════
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ═══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION
# ═══════════════════════════════════════════════════════════════════════════════

# JWT signing secret — minimum 32 characters, random
JWT_SECRET=change-this-to-a-long-random-string-in-production


# ═══════════════════════════════════════════════════════════════════════════════
# BULLMQ / REDIS (REQUIRED for production async filing)
# ═══════════════════════════════════════════════════════════════════════════════

# Local: redis://localhost:6379
# Redis Cloud: redis://default:password@host:port
# Upstash (TLS): rediss://default:password@host.upstash.io:6380
REDIS_URL=redis://localhost:6379


# ═══════════════════════════════════════════════════════════════════════════════
# COURT FILING PROVIDER — Phase 7 Credentialed API Swap Plan
# ═══════════════════════════════════════════════════════════════════════════════

# Active provider. Options: simulator | florida_tpv
# Change ONLY after completing the 7-Step Credentialed API Swap Plan.
# See FLORIDA_TPV_SWAP.md for full instructions.
COURT_PROVIDER=simulator


# ═══════════════════════════════════════════════════════════════════════════════
# FLORIDA TPV API CREDENTIALS
# ⚠️  LEAVE COMMENTED OUT until TPV certification is complete (Step 3+)
# ═══════════════════════════════════════════════════════════════════════════════

# Sandbox:    https://sandbox.efilingapi.flcourts.org/api/v1
# Production: https://efilingapi.flcourts.org/api/v1
# FLORIDA_TPV_API_URL=

# Issued by Florida Courts E-Filing Authority after TPV application approval
# FLORIDA_TPV_API_KEY=
# FLORIDA_TPV_CLIENT_ID=
# FLORIDA_TPV_CLIENT_SECRET=

# Optional tuning (defaults shown)
# FLORIDA_TPV_TIMEOUT_MS=30000
# FLORIDA_TPV_RETRIES=3


# ═══════════════════════════════════════════════════════════════════════════════
# MAKE.COM WEBHOOKS (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════════

# Court filing lifecycle events (accepted/rejected/timeout) — fired by BullMQ worker
# MAKE_COURT_WEBHOOK_URL=https://hook.us1.make.com/your-webhook-id

# Lead intake webhook (existing integration)
# MAKE_WEBHOOK_URL=https://hook.us1.make.com/your-intake-webhook-id


# ═══════════════════════════════════════════════════════════════════════════════
# AI / OPENAI (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════════

# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4o


# ═══════════════════════════════════════════════════════════════════════════════
# STAGING OVERRIDES — for .env.staging
# ═══════════════════════════════════════════════════════════════════════════════
# NODE_ENV=staging
# COURT_PROVIDER=florida_tpv   ← Enable ONLY after Step 4 (parity tests pass)
# FLORIDA_TPV_API_URL=https://sandbox.efilingapi.flcourts.org/api/v1
# REDIS_URL=redis://your-staging-redis:6379
