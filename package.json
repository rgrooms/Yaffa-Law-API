{
  "name": "yaffa-law-api",
  "version": "1.0.0",
  "description": "Yaffa Law Legal OS — Backend API",
  "main": "src/server.ts",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts",
    "dev:api": "nodemon --exec tsx src/server.ts",
    "dev:full": "concurrently --kill-others-on-fail --names 'REDIS,API,UI' --prefix-colors 'red,blue,green' \"bash scripts/start-redis.sh && sleep 1\" \"npm run dev:api\" \"cd ../yaffa-law-demo && npm run dev\"",
    "start": "tsx src/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "redis": "bash scripts/start-redis.sh",
    "health": "bash scripts/health-check.sh",
    "parity:simulator": "tsx src/court/parityTestHarness.ts --provider=simulator",
    "parity:tpv": "tsx src/court/parityTestHarness.ts --provider=florida_tpv"
  },
  "vitest": {
    "globals": true,
    "environment": "node",
    "include": [
      "src/**/__tests__/**/*.test.ts"
    ],
    "testTimeout": 60000
  },
  "dependencies": {
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@bull-board/ui": "^7.0.0",
    "@supabase/supabase-js": "^2.49.8",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.18.0",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/pdfkit": "^0.17.6",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.4",
    "pg": "^8.20.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^4.1.5"
  }
}
